  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "320744d0-89b6-4aba-bc4c-d385d409518f",
   "metadata": {},
   "outputs": [],
   "source": [
    "## construire les groupes \n",
    "score_m1=df[df[\"METHODE_ENTRAINEMENT\"]=='Méthode 1']['SCORE_INITIAL']\n",
    "score_m2=df[df[\"METHODE_ENTRAINEMENT\"]=='Méthode 2']['SCORE_INITIAL']\n",
    "score_c=df[df[\"METHODE_ENTRAINEMENT\"]=='Méthode classique']['SCORE_INITIAL']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "723d81a9-3653-41f3-b4c8-d0f76b73098a",
   "metadata": {},
   "outputs": [],
   "source": [
    "_,p_m1=shapiro(score_m1) # _ pour ignorer volontairement la statistique, elle ne sera pas utilisée\n",
    "_,p_m2=shapiro(score_m2)\n",
    "_,p_c=shapiro(score_c)\n",
    "print(p_m1.round(3))\n",
    "print(p_m2.round(3))\n",
    "print(p_c.round(3))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "07fb032b-b29b-4254-b66a-3f021d2e3156",
   "metadata": {},
   "source": [
    "- La normalité est vérifiée!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "206d90b0-0b0b-4e9b-ab65-04155b8135f2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Homogénéité des variances \n",
    "stat,pval = stats.levene(score_m1,score_m2,score_c,center=\"median\")\n",
    "print(pval.round(2))"
   ]
  },
