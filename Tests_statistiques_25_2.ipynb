    "print(p_vlue.round(3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3da649b4-28e1-42fb-9a81-ea0efaad7708",
   "metadata": {},
   "outputs": [],
   "source": [
    "stat,p_vlue=ttest_ind(age_h,age_f)\n",
    "print(p_vlue.round(3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "af925ed6-e634-49ab-9c91-9cc3e58a3472",
   "metadata": {},
   "outputs": [],
   "source": [
    "stat,p_vlue=ttest_ind(age_h,age_f,equal_var=False)\n",
    "print(p_vlue.round(3))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "247f5511-434b-4515-9d8d-92cf894db427",
   "metadata": {},
   "source": [
