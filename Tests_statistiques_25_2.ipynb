    "print(df[\"METHODE_ENTRAINEMENT\"].unique())\n",
    "age_m1=df[df[\"METHODE_ENTRAINEMENT\"]=='Méthode 1'][\"AGE\"]\n",
    "age_m2=df[df[\"METHODE_ENTRAINEMENT\"]=='Méthode 2'][\"AGE\"]\n",
